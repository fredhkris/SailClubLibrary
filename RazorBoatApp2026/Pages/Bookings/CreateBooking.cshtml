@page
@using SailClubLibrary.Models
@model RazorBoatApp2026.Pages.Bookings.CreateBookingModel
@{
    ViewData["Title"] = "Create Booking";
}
<h1>Create Booking</h1>
<label>Boat SailNumber</label>: @Model.Boat.SailNumber
<br />
<label>Boat Model</label>: @Model.Boat.Model
<br />
<label>Boat YearOfConstruction</label>: @Model.Boat.YearOfConstruction
<br />
<form method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" name="sailNumber" value="@Model.Boat.SailNumber" />
    <div class="form-group">
        <label asp-for="@Model.StartDate" class="control-label"></label>
        <input asp-for="@Model.StartDate" type="date" class="form-control" />
        <span asp-validation-for="@Model.StartDate"></span>
    </div>
    <div class="form-group">
        <label asp-for="@Model.EndDate" class="control-label"></label>
        <input asp-for="@Model.EndDate" type="date" class="form-control" />
        <span asp-validation-for="@Model.EndDate"></span>
    </div>
    <div class="form-group">
        <label asp-for="@Model.Destination" class="control-label"></label>
        <input asp-for="@Model.Destination" class="form-control" />
        <span asp-validation-for="@Model.Destination"></span>
    </div>
    <div class="form-group">
        <label asp-for="@Model.PhoneNumber" class="control-label"></label>
        <input asp-for="@Model.PhoneNumber" class="form-control" />
        <span asp-validation-for="@Model.PhoneNumber"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Create Booking" class="btn btn-primary" />
    </div>
</form>